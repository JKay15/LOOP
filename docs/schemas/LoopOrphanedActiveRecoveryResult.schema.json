{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopOrphanedActiveRecoveryResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recovery_decision",
    "node_id",
    "workspace_root",
    "state_root",
    "node_ref",
    "delegation_ref",
    "child_prompt_ref",
    "launch_spec",
    "confirmed_launch_result_ref",
    "confirmed_runtime_status_ref",
    "confirmed_runtime_recovery_reason",
    "accepted_envelope_id",
    "accepted_envelope_note",
    "recovery_context_ref",
    "recovery_request_ref",
    "recovery_result_ref"
  ],
  "properties": {
    "recovery_decision": { "type": "string", "enum": ["accepted"] },
    "node_id": { "type": "string", "minLength": 1 },
    "workspace_root": { "type": "string", "minLength": 1 },
    "state_root": { "type": "string", "minLength": 1 },
    "node_ref": { "type": "string", "minLength": 1 },
    "delegation_ref": { "type": "string", "minLength": 1 },
    "child_prompt_ref": { "type": "string", "minLength": 1 },
    "launch_spec": { "type": "object" },
    "confirmed_launch_result_ref": { "type": "string", "minLength": 1 },
    "confirmed_runtime_status_ref": { "type": "string", "minLength": 1 },
    "confirmed_runtime_recovery_reason": { "type": "string", "minLength": 1 },
    "accepted_envelope_id": { "type": "string" },
    "accepted_envelope_note": { "type": "string" },
    "latest_implementer_result_ref": { "type": "string" },
    "recovery_context_ref": { "type": "string", "minLength": 1 },
    "recovery_request_ref": { "type": "string", "minLength": 1 },
    "recovery_result_ref": { "type": "string", "minLength": 1 }
  }
}
