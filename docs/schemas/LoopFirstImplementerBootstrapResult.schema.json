{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopFirstImplementerBootstrapResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "reuse_decision",
    "node_id",
    "workflow_scope",
    "artifact_scope",
    "terminal_authority_scope",
    "workspace_root",
    "state_root",
    "node_ref",
    "delegation_ref",
    "handoff_json_ref",
    "handoff_md_ref",
    "child_prompt_ref",
    "workspace_live_artifact_ref",
    "artifact_publication_receipt_ref",
    "artifact_publication_runner_ref",
    "workspace_result_sink_ref",
    "kernel_result_sink_ref",
    "evaluator_submission_ref",
    "evaluator_runner_ref",
    "launch_spec",
    "bootstrap_result_ref"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": [
        "fresh",
        "continue_exact"
      ]
    },
    "reuse_decision": {
      "type": "string",
      "enum": [
        "fresh",
        "continue_exact"
      ]
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_scope": {
      "type": "string",
      "enum": [
        "generic",
        "whole_paper_formalization"
      ]
    },
    "artifact_scope": {
      "type": "string",
      "enum": [
        "task",
        "slice"
      ]
    },
    "terminal_authority_scope": {
      "type": "string",
      "enum": [
        "local",
        "whole_paper"
      ]
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1
    },
    "state_root": {
      "type": "string",
      "minLength": 1
    },
    "node_ref": {
      "type": "string",
      "minLength": 1
    },
    "delegation_ref": {
      "type": "string",
      "minLength": 1
    },
    "handoff_json_ref": {
      "type": "string",
      "minLength": 1
    },
    "handoff_md_ref": {
      "type": "string",
      "minLength": 1
    },
    "child_prompt_ref": {
      "type": "string",
      "minLength": 1
    },
    "workspace_live_artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "artifact_publication_receipt_ref": {
      "type": "string",
      "minLength": 1
    },
    "artifact_publication_runner_ref": {
      "type": "string",
      "minLength": 1
    },
    "workspace_result_sink_ref": {
      "type": "string",
      "minLength": 1
    },
    "kernel_result_sink_ref": {
      "type": "string",
      "minLength": 1
    },
    "evaluator_submission_ref": {
      "type": "string",
      "minLength": 1
    },
    "evaluator_runner_ref": {
      "type": "string",
      "minLength": 1
    },
    "bootstrap_result_ref": {
      "type": "string",
      "minLength": 1
    },
    "launch_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "argv",
        "env",
        "cwd",
        "stdin_path"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        },
        "stdin_path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
