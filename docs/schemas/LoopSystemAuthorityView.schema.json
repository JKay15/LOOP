{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopSystemAuthorityView",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "root_goal",
    "root_node_id",
    "status",
    "node_graph",
    "node_lifecycle",
    "effective_requirements",
    "budget_view",
    "blocked_reasons",
    "delegation_map",
    "active_evaluator_lanes",
    "active_child_nodes",
    "truthful_active_child_nodes",
    "nonlive_active_child_nodes",
    "planned_child_nodes"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "root_goal": {
      "type": "string",
      "minLength": 1
    },
    "root_node_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "node_graph": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node_id",
          "parent_node_id",
          "node_kind",
          "goal_slice",
          "workflow_scope",
          "artifact_scope",
          "terminal_authority_scope",
          "generation",
          "round_id",
          "status",
          "runtime_state",
          "runtime_projection"
        ],
        "properties": {
          "node_id": {
            "type": "string",
            "minLength": 1
          },
          "parent_node_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "node_kind": {
            "type": "string",
            "minLength": 1
          },
          "goal_slice": {
            "type": "string",
            "minLength": 1
          },
          "workflow_scope": {
            "type": "string",
            "enum": [
              "generic",
              "whole_paper_formalization"
            ]
          },
          "artifact_scope": {
            "type": "string",
            "enum": [
              "task",
              "slice"
            ]
          },
          "terminal_authority_scope": {
            "type": "string",
            "enum": [
              "local",
              "whole_paper"
            ]
          },
          "generation": {
            "type": "integer",
            "minimum": 0
          },
          "round_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "runtime_state": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "attachment_state",
              "observed_at",
              "summary",
              "observation_kind",
              "evidence_refs"
            ],
            "properties": {
              "attachment_state": {
                "type": "string",
                "enum": [
                  "UNOBSERVED",
                  "ATTACHED",
                  "LOST",
                  "TERMINAL"
                ]
              },
              "observed_at": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "observation_kind": {
                "type": "string"
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "live_process_trusted": {
                "type": "boolean"
              },
              "pid": {
                "type": "integer",
                "minimum": 0
              },
              "pid_alive": {
                "type": "boolean"
              },
              "lease_epoch": {
                "type": "integer",
                "minimum": 0
              },
              "lease_owner_id": {
                "type": "string"
              },
              "lease_freshness": {
                "type": "string"
              },
              "lease_source": {
                "type": "string"
              },
              "lease_duration_s": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "lease_expires_at": {
                "type": "string"
              },
              "launch_event_id": {
                "type": "string"
              },
              "status_result_ref": {
                "type": "string"
              },
              "runtime_ref": {
                "type": "string"
              },
              "process_fingerprint": {
                "type": "string"
              },
              "process_started_at_utc": {
                "type": "string"
              }
            }
          },
          "runtime_projection": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_kind",
              "source_event_id",
              "source_seq",
              "raw_attachment_state",
              "effective_attachment_state",
              "lease_freshness",
              "lease_epoch",
              "lease_owner_id",
              "observed_at",
              "truthful_active"
            ],
            "properties": {
              "source_kind": {
                "type": "string",
                "enum": [
                  "runtime_liveness_event",
                  "node_runtime_state"
                ]
              },
              "source_event_id": {
                "type": "string"
              },
              "source_seq": {
                "type": "integer",
                "minimum": 0
              },
              "raw_attachment_state": {
                "type": "string",
                "enum": [
                  "UNOBSERVED",
                  "ATTACHED",
                  "LOST",
                  "TERMINAL"
                ]
              },
              "effective_attachment_state": {
                "type": "string",
                "enum": [
                  "UNOBSERVED",
                  "ATTACHED",
                  "LOST",
                  "TERMINAL"
                ]
              },
              "lease_freshness": {
                "type": "string"
              },
              "lease_epoch": {
                "type": "integer",
                "minimum": 0
              },
              "lease_owner_id": {
                "type": "string"
              },
              "observed_at": {
                "type": "string"
              },
              "truthful_active": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "node_lifecycle": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "effective_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "budget_view": {
      "type": "object"
    },
    "blocked_reasons": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "delegation_map": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "active_evaluator_lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "lane",
          "verdict",
          "round_id",
          "summary"
        ],
        "properties": {
          "node_id": {
            "type": "string"
          },
          "lane": {
            "type": "string"
          },
          "verdict": {
            "type": "string"
          },
          "round_id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "active_child_nodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "truthful_active_child_nodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nonlive_active_child_nodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "planned_child_nodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lease_fencing_summary": {
      "type": "object"
    }
  }
}
