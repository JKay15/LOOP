{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopSystemNodeSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "node_id",
    "node_kind",
    "goal_slice",
    "parent_node_id",
    "generation",
    "round_id",
    "execution_policy",
    "reasoning_profile",
    "budget_profile",
    "allowed_actions",
    "workflow_scope",
    "artifact_scope",
    "terminal_authority_scope",
    "progress_checkpoints",
    "workspace_root",
    "codex_home",
    "depends_on_node_ids",
    "activation_condition",
    "activation_rationale",
    "runtime_state",
    "delegation_ref",
    "result_sink_ref",
    "lineage_ref",
    "status"
  ],
  "properties": {
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "node_kind": {
      "type": "string",
      "minLength": 1
    },
    "goal_slice": {
      "type": "string",
      "minLength": 1
    },
    "parent_node_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "generation": {
      "type": "integer",
      "minimum": 0
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_policy": {
      "type": "object",
      "required": [
        "agent_provider",
        "sandbox_mode"
      ],
      "properties": {
        "agent_provider": {
          "type": "string",
          "minLength": 1
        },
        "sandbox_mode": {
          "type": "string",
          "minLength": 1
        },
        "retry_policy": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "reasoning_profile": {
      "type": "object",
      "required": [
        "role",
        "thinking_budget"
      ],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "thinking_budget": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "budget_profile": {
      "type": "object",
      "additionalProperties": true
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflow_scope": {
      "type": "string",
      "enum": [
        "generic",
        "whole_paper_formalization"
      ]
    },
    "artifact_scope": {
      "type": "string",
      "enum": [
        "task",
        "slice"
      ]
    },
    "terminal_authority_scope": {
      "type": "string",
      "enum": [
        "local",
        "whole_paper"
      ]
    },
    "required_output_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "startup_required_output_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "progress_checkpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "checkpoint_id",
          "description",
          "required_any_of",
          "window_s"
        ],
        "properties": {
          "checkpoint_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "required_any_of": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "window_s": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    "workspace_root": {
      "type": "string"
    },
    "codex_home": {
      "type": "string"
    },
    "depends_on_node_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "activation_condition": {
      "type": "string"
    },
    "activation_rationale": {
      "type": "string"
    },
    "runtime_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attachment_state",
        "observed_at",
        "summary",
        "observation_kind",
        "evidence_refs"
      ],
      "properties": {
        "attachment_state": {
          "type": "string",
          "enum": [
            "UNOBSERVED",
            "ATTACHED",
            "LOST",
            "TERMINAL"
          ]
        },
        "observed_at": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "observation_kind": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "live_process_trusted": {
          "type": "boolean"
        },
        "pid": {
          "type": "integer",
          "minimum": 0
        },
        "pid_alive": {
          "type": "boolean"
        },
        "lease_epoch": {
          "type": "integer",
          "minimum": 0
        },
        "lease_owner_id": {
          "type": "string"
        },
        "lease_freshness": {
          "type": "string"
        },
        "lease_source": {
          "type": "string"
        },
        "lease_duration_s": {
          "type": [
            "number",
            "null"
          ]
        },
        "lease_expires_at": {
          "type": "string"
        },
        "launch_event_id": {
          "type": "string"
        },
        "status_result_ref": {
          "type": "string"
        },
        "runtime_ref": {
          "type": "string"
        },
        "process_fingerprint": {
          "type": "string"
        },
        "process_started_at_utc": {
          "type": "string"
        }
      }
    },
    "delegation_ref": {
      "type": "string"
    },
    "result_sink_ref": {
      "type": "string"
    },
    "authoritative_result_ref": {
      "type": "string"
    },
    "authoritative_result_status": {
      "type": "string"
    },
    "authoritative_result_outcome": {
      "type": "string"
    },
    "authoritative_result_summary": {
      "type": "string"
    },
    "authoritative_evaluator_verdict": {
      "type": "string"
    },
    "authoritative_evaluation_report_ref": {
      "type": "string"
    },
    "authoritative_reviewer_response_ref": {
      "type": "string"
    },
    "authoritative_workspace_result_sink_ref": {
      "type": "string"
    },
    "authoritative_workspace_mirror_ref": {
      "type": "string"
    },
    "lineage_ref": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "PLANNED",
        "ACTIVE",
        "BLOCKED",
        "COMPLETED",
        "FAILED"
      ]
    },
    "projection_name": {
      "type": "string",
      "minLength": 1
    },
    "last_applied_seq": {
      "type": "integer",
      "minimum": 0
    },
    "projection_updated_at": {
      "type": "string"
    },
    "source_event_journal_ref": {
      "type": "string"
    },
    "projection_bundle_ref": {
      "type": "string"
    }
  }
}
